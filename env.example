# For Neon/hosted Postgres, include sslmode=verify-full to match pg driver expectations
DATABASE_URL="postgresql://USER:PASSWORD@host:5432/meat?sslmode=verify-full"

# Comma-separated emails that receive ADMIN role on register/login
ADMIN_EMAIL="you@example.com"

# Vercel Blob (create in Vercel project → Storage → Blob)
BLOB_READ_WRITE_TOKEN=""
